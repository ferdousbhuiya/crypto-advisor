DATABASE_URL=postgresql://user:password@localhost:5432/crypto_advisor
JWT_SECRET=change-me-to-a-long-random-string
CLIENT_ORIGIN=http://localhost:5180
PORT=4000
# Optional: caches CoinGecko responses in Redis so the cache survives
# restarts/redeploys instead of resetting to empty every time. If unset,
# falls back to an in-memory cache only (works, just cold on every deploy).
REDIS_URL=redis://default:password@localhost:6379
